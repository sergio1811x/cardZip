{
  "name": "cardzip",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/dev.ts",
    "build": "npm run clean && tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "clean": "rm -rf dist",
    "test:quality": "vitest run src/core/cardzipQuality.test.ts src/core/procurementQuality.test.ts src/core/electricalQuality.test.ts src/core/reportRenderingQuality.test.ts src/core/textQuality.test.ts src/core/docValueQuality.test.ts src/core/knifeQuality.test.ts src/core/generatedDocQuality.test.ts --config vitest.config.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.0",
    "@upstash/redis": "^1.34.0",
    "adm-zip": "^0.5.16",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "sharp": "^0.35.2",
    "telegraf": "^4.16.3",
    "ws": "^8.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "@vercel/node": "^5.8.17",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.9"
  }
}
