# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ADMIN_TG_ID=

# Public app URL used to chain Vercel steps
APP_URL=https://your-app.vercel.app
PUBLIC_APP_URL=https://your-app.vercel.app

# Supabase service role access
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# OpenRouter / AI
OPENROUTER_API_KEY=
OPENROUTER_REFERER=https://your-app.vercel.app
OPENROUTER_TITLE=CardZip

# Optional fallback AI provider
FIREWORKS_API_KEY=

# China product provider
ELIM_API_KEY=
RAPIDAPI_KEY=

# WB parser microservice. Required for WB analog search.
WB_PARSER_URL=https://your-wb-parser.example.com
WB_PARSER_SECRET=
WB_PARSER_TIMEOUT_MS=30000
WB_PARSER_LIMIT=50
WB_PARSER_RETRIES=1

# Redis locks/cache. Recommended in production.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Expert Writer / QA are enabled by default for paid MVP. Prompts are compact,
# and deterministic validators repair common issues before blocking reports.
# Values: always | confirmed_market | off
CARDZIP_EXPERT_WRITER_MODE=always

# Values: always | critical_only | off
CARDZIP_QA_GATE_MODE=always

# If all QA models are unavailable but code validators passed:
# send_code_validated = send the deterministic validated report; fail_closed = block.
CARDZIP_QA_UNAVAILABLE_POLICY=send_code_validated

# Railway/VPS pipeline mode
# detached = trigger next pipeline step in background and do not abort after 8s.
# On Railway this should stay detached/background because provider + LLM stages can run 60–180s.
PIPELINE_TRIGGER_MODE=detached
PROCESSING_LOCK_TTL_SEC=900
STEP_LOCK_TTL_SEC=900
JOB_STUCK_TIMEOUT_MS=600000

# For Railway set APP_URL/PUBLIC_APP_URL to your deployed public domain,
# or leave empty if callbacks run inside the same container and local fallback is enough.
# Example: https://your-service.up.railway.app
