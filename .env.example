# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ADMIN_TG_ID=

# Public/internal app URL used to trigger pipeline steps.
# Railway: set APP_URL/PUBLIC_APP_URL to your public Railway domain.
# Optional INTERNAL_APP_URL can be http://127.0.0.1:${PORT} only when you know the internal port.
APP_URL=https://your-service.up.railway.app
PUBLIC_APP_URL=https://your-service.up.railway.app
INTERNAL_APP_URL=

# Supabase service role access
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# OpenRouter / AI
OPENROUTER_API_KEY=
OPENROUTER_REFERER=https://your-service.up.railway.app
OPENROUTER_TITLE=CardZip

# Optional fallback AI provider
FIREWORKS_API_KEY=

# China product provider
ELIM_API_KEY=
RAPIDAPI_KEY=

# Optional legacy marketplace research module. Not required for procurement-package MVP.
WB_PARSER_URL=https://your-wb-parser.example.com
WB_PARSER_SECRET=
WB_PARSER_TIMEOUT_MS=30000
WB_PARSER_LIMIT=50
WB_PARSER_RETRIES=1

# Redis locks/cache. Recommended in production.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Expert Writer / QA are enabled by default for paid MVP. Prompts are compact,
# and deterministic validators repair common issues before blocking reports.
# Values: always | confirmed_market | off
CARDZIP_EXPERT_WRITER_MODE=always

# Values: always | critical_only | off
CARDZIP_QA_GATE_MODE=critical_only

# If all QA models are unavailable but code validators passed:
# send_code_validated = send the deterministic validated report; fail_closed = block.
CARDZIP_QA_UNAVAILABLE_POLICY=send_code_validated

# MVP behavior: validator/QA repair and warn, but do not stop a successfully parsed procurement package.
# Set to true only for internal regression/debug fail-closed runs.
CARDZIP_VALIDATOR_FAIL_CLOSED=false
CARDZIP_QA_FAIL_CLOSED=false

# Railway/VPS pipeline mode
# local = trigger next pipeline step inside the same Railway container, without APP_URL self-fetch.
# This is the safest mode for single-service Railway deployments and fixes SKU continuation freezes.
# Use detached_http only if you intentionally run API steps on a separate public service.
PIPELINE_TRIGGER_MODE=local
PROCESSING_LOCK_TTL_SEC=900
STEP_LOCK_TTL_SEC=900
JOB_STUCK_TIMEOUT_MS=600000

# For Railway do not leave APP_URL pointing to old Vercel. Wrong APP_URL makes SKU continuation
# freeze after selection because /api/step2-ai is triggered on the wrong host.

# LLM routing
CARDZIP_SKU_TRANSLATOR_MODELS=google/gemini-2.5-flash-lite,deepseek/deepseek-v4-flash,stepfun/step-3.7-flash
PRODUCT_CANONICALIZER_MULTIMODAL_MODELS=qwen/qwen3.7-plus,google/gemini-2.5-flash-lite,stepfun/step-3.7-flash
PRODUCT_CANONICALIZER_TEXT_MODELS=deepseek/deepseek-v4-pro,qwen/qwen3.7-plus,minimax/minimax-m2.7
CARDZIP_CN_TRANSLATOR_MODELS=google/gemini-2.5-flash-lite,deepseek/deepseek-v4-flash,stepfun/step-3.7-flash
