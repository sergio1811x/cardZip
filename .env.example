# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ADMIN_TG_ID=

# Public app URL used to chain Vercel steps
APP_URL=https://your-app.vercel.app
PUBLIC_APP_URL=https://your-app.vercel.app

# Supabase service role access
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# OpenRouter / AI
OPENROUTER_API_KEY=
OPENROUTER_REFERER=https://your-app.vercel.app
OPENROUTER_TITLE=CardZip

# Optional fallback AI provider
FIREWORKS_API_KEY=

# China product provider
ELIM_API_KEY=
RAPIDAPI_KEY=

# WB parser microservice. Required for WB analog search.
WB_PARSER_URL=https://your-wb-parser.example.com
WB_PARSER_SECRET=
WB_PARSER_TIMEOUT_MS=30000
WB_PARSER_LIMIT=50
WB_PARSER_RETRIES=1

# Redis locks/cache. Recommended in production.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Expert Writer is optional and expensive. Keep off for ordinary paid MVP flow;
# deterministic Decision Layer + validators build the user report.
# Values: off | confirmed_market | always
CARDZIP_EXPERT_WRITER_MODE=off

# LLM QA mode. Default skips expensive LLM QA when deterministic validator already repaired/passed.
# Values: critical_only | always | off
CARDZIP_QA_GATE_MODE=critical_only
